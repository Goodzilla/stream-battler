datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String      @id @default(uuid())
  twitchId    String      @unique
  username    String
  displayName String
  isAdmin     Boolean     @default(false)
  gold        Int         @default(100)
  activeClass String      @default("WARRIOR")
  shopStock   String      @default("[]") // JSON string of 3 merchant items
  createdAt   DateTime    @default(now())
  characters  Character[]
  items       Item[]
}

model Character {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  class         String   // 'WARRIOR' | 'MAGE' | 'CLERIC' | 'ROGUE' | 'RANGER'
  level         Int      @default(1)
  xp            Int      @default(0)
  talents       String   @default("[]")
  passives      String   @default("[]")
  equippedItems Item[]   @relation("EquippedItems")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, class])
}

model Item {
  id                  String     @id @default(uuid())
  userId              String
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  equippedCharacterId String?
  equippedCharacter   Character? @relation("EquippedItems", fields: [equippedCharacterId], references: [id], onDelete: SetNull)
  name                String
  slot                String     // 'WEAPON' | 'ARMOR' | 'ACCESSORY'
  rarity              String     // 'COMMON' | 'UNCOMMON' | 'RARE' | 'EPIC' | 'LEGENDARY'
  itemLevel           Int        @default(1)
  baseAttack          Float      @default(0)
  baseDefense         Float      @default(0)
  affixes             String     @default("[]") // JSON string of rolled affixes
  isEquipped          Boolean    @default(false)
  createdAt           DateTime   @default(now())
}

model RaidHistory {
  id           String   @id @default(uuid())
  streamerName String
  bossName     String
  bossLevel    Int
  participants Int
  success      Boolean
  createdAt    DateTime @default(now())
}
